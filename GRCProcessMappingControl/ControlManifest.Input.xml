<?xml version="1.0" encoding="utf-8"?>
<manifest>
  <control
    namespace="GRC"
    constructor="GRCProcessMappingControl"
    version="0.0.1"
    display-name-key="GRCProcessMappingControl"
    description-key="GRCProcessMappingControl_Desc"
    control-type="standard"
